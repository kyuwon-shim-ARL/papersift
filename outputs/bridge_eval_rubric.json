{
  "protocol": {
    "evaluator": "single_author_pilot",
    "scale": {
      "novelty": "1-5 Likert (1=obvious, 5=highly novel)",
      "feasibility": "1-5 Likert (1=infeasible, 5=immediately actionable)",
      "relevance": "binary (0=irrelevant to virtual cell research, 1=relevant)"
    },
    "selection_criteria": {
      "source": "e025 t1_rank_norm.top_20",
      "sort": "bridge_score descending",
      "intra": "top 5 intra_cluster by bridge_score",
      "cross": "top 5 cross_cluster by bridge_score",
      "total": 10,
      "tie_breaking": "if fewer than 5 in category, fill from other category"
    }
  },
  "evaluation_form_schema": {
    "bridge_id": {
      "type": "string",
      "description": "Unique identifier (rank-based)"
    },
    "source_cluster": {
      "type": "string",
      "description": "Source cluster label"
    },
    "target_cluster": {
      "type": "string",
      "description": "Target cluster label (same as source for intra)"
    },
    "entity_pair": {
      "type": "string",
      "description": "Entity pair or cluster pair description"
    },
    "bridge_score": {
      "type": "number",
      "description": "Rank-normalized bridge score from e025"
    },
    "novelty_score": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "description": "Novelty rating"
    },
    "feasibility_score": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "description": "Feasibility rating"
    },
    "relevance_binary": {
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "description": "Domain relevance"
    },
    "evaluator_id": {
      "type": "string",
      "description": "Evaluator identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "ISO 8601",
      "description": "Evaluation timestamp"
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes"
    }
  },

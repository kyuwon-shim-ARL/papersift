      "overall_interest": "1-5 Likert (1=no interest, 2=low, 3=moderate, 4=high, 5=would pursue immediately)",
      "relevance": "binary (0=irrelevant to virtual cell research, 1=relevant)"
    },
    "go_no_go": {
      "worth_trying_definition": "novelty >= 3 AND feasibility >= 3 AND overall_interest >= 3",
      "GO": ">= 5/10 worth-trying",
      "CONDITIONAL": "3-4/10 worth-trying",
      "NO_GO": "< 3/10 worth-trying → scoring formula 재검토"
    },
    "pilot": {
      "size": 3,
      "items": ["B01", "B06", "B09"],
      "rationale": "1 intra (highest score) + 1 cross (highest score) + 1 cross (lowest score) for range coverage",
      "adjustment_criteria": {
        "variance_threshold": 2.0,
        "action_if_exceeded": "clarify scale anchors in evaluation guide",
        "time_threshold_minutes": 15,
        "action_if_exceeded": "reduce notes field to optional, simplify rubric"
      },
      "proceed_to_main": "pilot results reviewed, rubric adjusted if needed, then evaluate remaining 7 items"
